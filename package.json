{
  "name": "create-lumos-app",
  "version": "0.1.12",
  "description": "Scaffolding CLI for Lumos Fellows — create Next.js or Expo apps with best-practice defaults",
  "type": "module",
  "bin": {
    "create-lumos-app": "bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "templates/"
  ],
  "scripts": {
    "start": "node bin/cli.js",
    "test": "node --test --test-force-exit test/e2e.test.mjs",
    "test:unit": "node --experimental-test-module-mocks --test test/utils.test.mjs test/skills.test.mjs test/supabase.test.mjs test/templates.test.mjs",
    "lint": "biome lint bin src test",
    "format": "biome format --write bin src test biome.json package.json",
    "check": "biome check --write bin src test",
    "prerelease": "pnpm test:unit && pnpm lint",
    "release": "npm version patch && git push --follow-tags && npm publish --access public"
  },
  "keywords": [
    "create",
    "lumos",
    "nextjs",
    "expo",
    "scaffold",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lumos-fellows/create-lumos-app.git"
  },
  "author": "Lumos Fellows",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "picocolors": "^1.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.0"
  },
  "packageManager": "pnpm@10.29.3+sha256.a74f4dbd3f5a7ca874d004135271f0b697b683bf1fd2fc2133961161cd25b29c"
}
